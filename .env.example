# ============================================================
# AI_DESK — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ── Gateway ─────────────────────────────────────────────────
AI_DESK_BIND=127.0.0.1
AI_DESK_PORT=18789

# Master Encryption Passphrase (AES-256-GCM)
# Encrypts all secrets, sessions, tokens, and audit log at rest.
# If lost, all encrypted data is UNRECOVERABLE. Keep this safe.
AI_DESK_MASTER_KEY=change-me-to-a-strong-random-passphrase

# Directory for runtime data (SQLite DBs, state files)
# AI_DESK_DATA_DIR=./.ai-desk-data

# ── Model Providers ─────────────────────────────────────────
# Set keys here OR configure via Dashboard → Credentials (stored encrypted).
# At least ONE provider must be available.

# Anthropic — direct API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=

# Anthropic — Claude Code login (no key needed)
#   Install Claude Code: https://claude.ai/code  then run it once.
#   AI_DESK auto-detects ~/.claude/.credentials.json — no env var needed.

# Google / Gemini — direct API key (https://aistudio.google.com/app/apikey)
GOOGLE_AI_API_KEY=

# OpenRouter — access 200+ models via one key (https://openrouter.ai/keys)
#   Model names in config: "openrouter/anthropic/claude-sonnet-4-5"
#                          "openrouter/openai/gpt-4o"
#                          "openrouter/meta-llama/llama-3.3-70b-instruct"
OPENROUTER_API_KEY=

# Google OAuth sign-in (Dashboard → Credentials → Sign in with Google).
# Create an OAuth 2.0 client in Google Cloud Console:
#   APIs & Services → Credentials → Create OAuth client ID
#   Application type: "TVs and Limited Input devices"
#   Enable: Generative Language API
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Messaging Adapters ──────────────────────────────────────
# Required if messaging.telegram is enabled in ai-desk.json
# TELEGRAM_BOT_TOKEN=

# Required if messaging.discord is enabled in ai-desk.json
# DISCORD_BOT_TOKEN=

# ── MCP / Skill Servers ─────────────────────────────────────
# Required if the brave-search.skill.json is enabled
# BRAVE_API_KEY=

# Add any other env vars your skill MCP servers need here,
# then reference them in the skill JSON as "${VAR_NAME}".
